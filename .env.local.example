# Supabase — Database + Auth (auth was previously on Clerk; fully on Supabase now)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare R2 — File Storage (logos, documents)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=stratawise-company-logos
R2_PUBLIC_URL=https://your-r2-public-domain.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-domain.com

# Resend — Email (optional in dev — omit to fall back to console logging)
RESEND_API_KEY=re_...
RESEND_INVITES_FROM=StrataWise <noreply@myocm.com.au>
RESEND_LEVIES_FROM=StrataWise <noreply@myocm.com.au>
RESEND_SYSTEM_FROM=StrataWise <noreply@myocm.com.au>

# The bare sender domain used to deep-link "Open in Gmail" on the OTP
# verification screen. Should match the domain in the RESEND_*_FROM
# addresses so the Gmail search pre-filters to your real sender.
NEXT_PUBLIC_SENDER_DOMAIN=myocm.com.au

# App URL — used in outbound email links (reauth, gap report, etc.)
NEXT_PUBLIC_APP_URL=https://app.myocm.com.au

# Google Maps Places API — VIC address autocomplete on onboarding +
# subdivision creation. Restrict the key to the Places JS API and to your
# domains. Component degrades to a plain text input if this is unset.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Gemini — used by the OC creation wizard to parse Plan-of-Subdivision PDFs.
# Accepts TWO formats:
#   (a) Service-account JSON (recommended for production): paste the full JSON
#       contents — the parser switches to Vertex AI mode automatically and
#       infers project_id from the JSON. Vertex AI does not train on inputs.
#   (b) Bare AI Studio key (AIza...): switches to AI Studio mode. Only use a
#       BILLED key — the free tier trains on customer data.
GEMINI_API_KEY=

# Optional region override for Vertex AI mode. Defaults to `global` — Vertex
# routes to the closest region hosting Gemini 2.5 Pro. Set to e.g.
# `us-central1` only if you have a contractual reason to pin a region.
# Note: gemini-2.5-pro is NOT in australia-southeast1; setting that here will
# return 404.
GEMINI_LOCATION=

# Google Document AI — OCR for every uploaded document (full-text search).
# Reuses the GEMINI_API_KEY service-account JSON above. Create a "Document
# OCR" processor in the Document AI console (~$1.50 / 1000 pages, no
# training), copy its ID here, and grant the service account
# `roles/documentai.apiUser`.
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
# Multi-region location of the processor. "us" or "eu" — must match where the
# processor was created.
GOOGLE_DOCUMENT_AI_LOCATION=us

# Bank statement ingest — Macquarie DEFT TXN/PAY file parser and generic CSV
# imports are the only paths supported. No external API keys required.

# Trigger.dev — scheduled tasks (overdue draft batches, interest accrual)
# Obtain from the Trigger.dev dashboard after running `npx trigger.dev@latest init`.
# Both are required to build and deploy /trigger/*.ts tasks. They are NOT read
# by the Next.js app at runtime.
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_PROJECT_ID=proj_...
