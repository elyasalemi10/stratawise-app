# Clerk — Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase — Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare R2 — File Storage (logos, documents)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=stratawise-company-logos
R2_PUBLIC_URL=https://your-r2-public-domain.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-domain.com

# Resend — Email (optional in dev — omit to fall back to console logging)
RESEND_API_KEY=re_...
RESEND_INVITES_FROM=Strata Wise <noreply@myocm.com.au>
RESEND_LEVIES_FROM=Strata Wise <noreply@myocm.com.au>
RESEND_SYSTEM_FROM=Strata Wise <noreply@myocm.com.au>

# App URL — used in outbound email links (reauth, gap report, etc.)
NEXT_PUBLIC_APP_URL=https://app.myocm.com.au

# Basiq — Bank feed integration (CDR)
BASIQ_API_KEY=your-basiq-server-api-key
BASIQ_API_BASE_URL=https://au-api.basiq.io
BASIQ_APPLICATION_ID=your-basiq-application-id
BASIQ_WEBHOOK_SECRET=whsec_base64-secret-from-basiq-dashboard
BASIQ_STATE_SECRET=at-least-32-characters-random-secret-for-csrf-state-tokens
NEXT_PUBLIC_BASIQ_CONSENT_BASE=https://consent.basiq.io
# Optional — only needed to run the live sandbox smoke test in verification
BASIQ_SANDBOX_CREDENTIALS=

# Trigger.dev — scheduled tasks (Basiq poll / reauth / expiry)
# Obtain from the Trigger.dev dashboard after running `npx trigger.dev@latest init`.
# Both are required to build and deploy /trigger/*.ts tasks. They are NOT read
# by the Next.js app at runtime.
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_PROJECT_ID=proj_...
