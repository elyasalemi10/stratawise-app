# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# MCP config (contains secrets)
.mcp.json

# throwaway / scratch artefacts (SQL deltas, stashed snippets, etc.)
# Convention: any file whose basename starts with "_" is scratch — never
# canonical. Canonical files (database-schema.sql, CONTEXT.md, CLAUDE.md,
# PRE_LAUNCH_CLEANUP.md, etc.) never use this prefix.
#
# Exception: Next.js uses `_components`, `_lib`, etc. inside app/ to mark
# private folders that are NOT route segments. Those are canonical and MUST
# be tracked. Add new exceptions here when adopting another `_xxx` private
# folder convention.
_*
!**/_components/
!**/_components/**
!**/_lib/
!**/_lib/**

# PP6-D-D smoke harness — ephemeral tsx scripts run pre-launch + deleted
# post-walk. No commit.
tmp-smoke/
